# FedAgent-Chain Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Experiment Tracking
MLFLOW_TRACKING_URI=http://localhost:5000
WANDB_API_KEY=your-wandb-api-key-here
WANDB_PROJECT=fedagent-chain
WANDB_ENTITY=your-wandb-entity

# HuggingFace
HF_TOKEN=your-huggingface-token-here
HF_HOME=~/.cache/huggingface

# Blockchain (for simulation)
BLOCKCHAIN_NODE_SECRET=change-this-to-a-random-secret-string
BLOCKCHAIN_STORAGE_PATH=./blockchain_storage

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-random-secret-key

# Data Storage
DATA_ROOT=./data
SYNTHETIC_DATA_PATH=./data/synthetic
PROCESSED_DATA_PATH=./data/processed

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Reproducibility
PYTHONHASHSEED=42
CUDA_VISIBLE_DEVICES=0

# DVC Remote (for dataset versioning)
DVC_REMOTE_URL=s3://your-bucket/fedagent-chain-data
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
